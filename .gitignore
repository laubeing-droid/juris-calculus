# LegalOS-Core .gitignore
# Blocks all local R&D, test, and blind-run artifacts.
# Only pure open-source source code reaches GitHub.

# Data artifacts (facts, timesheets, reports)
*.json
*.csv
*.xlsx
*.log

# Exception: US benchmark complaint templates (core + roadmap)
!tests/us_complaints/core/*.json
!tests/us_complaints/roadmap/*.json
!tests/fixtures/*.json

# IDE
.idea/
.vscode/
*.swp
*.swo

# Python cache
__pycache__/
*.pyc
*.pyo

# Private configs (only .example.yaml is allowed in)
*config.yaml
!*config.example.yaml

# OS files
.DS_Store
Thumbs.db

# Binary artifacts (vectors, indices)
chroma_db_ocr/
*.npy
*.pkl

# Rule backup files (concept injection/Augment 前备份)
configs/zh_CN/rules_pre_inject.yaml
configs/zh_CN/rules_augmented.yaml

# Sensitive credentials
.env
.env.*
*.pem
*.key

# Regenerated benchmark reports
tests/results/

# ── Interim build artifacts ──
configs/en_US/llm_distilled_batch*.json
configs/en_US/llm_distilled_pilot.json
configs/en_US/all_glossary_terms.json
configs/en_US/combined_all_terms.json
configs/en_US/pdf_glossary_terms.json
configs/en_US/US_complete.json
reports/asymmetry_distillation_v1.1.0.json
reports/parallax_detail_v1.1.0.json

# ── Exception: production JSONs ──
!configs/en_US/state_combined_terms.json
!configs/en_US/llm_distilled_full.json
!configs/prc_us_alignment/hk_us_divergence_matrix.json
!configs/prc_us_alignment/long_tail_collision_matrix.json
!configs/prc_us_alignment/trirail_matrix_report.json
!mcp_manifest.json
.hatch-pet-runs/

# Audit artifacts (deployed by pre-release-auditor, not tracked)
scripts/
.audit-*.md
.audit-version.json
.github/converge-briefing.md

# Planning files (working docs, not source)
task_plan.md
findings.md
progress.md
