{
  "version": "1.0",
  "description": "Cross-domain legal litigation mapping: domain A rules -> domain B impact",
  "domains": {
    "contract": {
      "alias": ["contract_law", "obligations"],
      "overlapping_concepts": {
        "breach": ["tort::duty_of_care", "criminal::actus_reus"],
        "obligation": ["administrative::regulated_activity", "tort::duty_of_care"],
        "damages": ["tort::damage", "criminal::harm_caused"]
      }
    },
    "tort": {
      "alias": ["tort_law", "civil_wrongs"],
      "overlapping_concepts": {
        "duty_of_care": ["contract::obligation", "administrative::regulated_activity"],
        "causation": ["criminal::actus_reus", "contract::delivery_breach"],
        "damage": ["contract::damages", "criminal::crime::assault"]
      }
    },
    "criminal": {
      "alias": ["criminal_law", "penal_code"],
      "overlapping_concepts": {
        "actus_reus": ["tort::causation", "contract::delivery_breach"],
        "harm_caused": ["tort::damage", "contract::damages"],
        "defense": ["administrative::license::active", "contract::force_majeure"]
      }
    },
    "administrative": {
      "alias": ["admin_law", "regulatory"],
      "overlapping_concepts": {
        "regulated_activity": ["contract::obligation", "tort::duty_of_care"],
        "license": ["contract::rights_granted", "criminal::defense"]
      }
    }
  },
  "cross_domain_cases": [
    {
      "case_id": "cross::contract_tort_overlap",
      "domain_a": "contract",
      "domain_b": "tort",
      "shared_facts": ["contract_exists", "duty_of_care", "breach_of_duty", "damage"],
      "description": "Breach of contract that also constitutes a tort (concurrent liability)"
    },
    {
      "case_id": "cross::criminal_admin_overlap",
      "domain_a": "criminal",
      "domain_b": "administrative",
      "shared_facts": ["regulated_activity", "taking_property", "without_consent"],
      "description": "Criminal act in a regulated industry (theft + license violation)"
    }
  ]
}
